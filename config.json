{
  "layer": "top",
  "position": "top",
  "spacing" : 0,

  "modules-left": [
    "clock",
    "custom/uptime",
    "custom/pomodoro"
  ],

  "modules-center": [
    "hyprland/workspaces"
  ],

  "modules-right": [
    "mpris",
    "pulseaudio",
    "bluetooth",
    "network",
    "group/power"
  ],

  "clock": {
    "format": "{:L%H:%M | %A, %d de %B}",
    "locale": "pt_BR.UTF-8",
    "tooltip": true,
    "tooltip-format": "{calendar}",
    "calendar": {
      "mode": "month",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#ffffff'><b>{}</b></span>",
        "days": "<span color='#bacaa9'>{}</span>",
        "weekdays": "<span color='#ffffff'>{}</span>",
        "today": "<span color='#ffffff'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-scroll-up": "shift_down",
      "on-scroll-down": "shift_up"
    }
  },

  "custom/uptime": {
    "format": "{}",
    "format-icon": ["´üó"],
    "tooltip": false,
    "interval": 1600,
    "exec": "$HOME/.config/waybar/scripts/uptime.sh"
  },

  "custom/pomodoro": {
    "format": "{}",
    "return-type": "json",
    "exec": "waybar-module-pomodoro --no-work-icons",
    "on-click": "waybar-module-pomodoro toggle",
    "on-click-right": "waybar-module-pomodoro reset",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "all-outputs": false,
    "persistent-workspaces": {
      "DP-1": [1, 2, 3, 4, 5],
      "HDMI-A-1": [6, 7, 8, 9, 10]
    },
    "format-icons": {
      "active": "´åÆ",
      "visible": "´åÆ",
      "default": "¯®▒"
    }
  },

  "mpris": {
    "format": "´üî  {title} - {artist}",
    "format-paused": "´üï  {title} - {artist}",
    "max-length": 35,
    "on-click": "playerctl play-pause"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "´æĞ",
    "format-icons": {
      "default": ["´ÇĞ", "´Çğ", "´Ç¿ "]
    },
    "on-click": "pavucontrol"
  },

  "bluetooth": {
    "format": "¾░é▓",
    "format-on": "{icon}",
    "format-off": "{icon}",
    "format-connected":"{icon}",
    "format-icons":{
        "on":"´èö",
        "off": "¾░é▓",
        "connected": "¾░é▒"
    },
    "on-click": "blueman-manager",
    "tooltip-format-connected":"{device_enumerate}"
  },

  "network": {
    "format-wifi": "´ç½",
    "format-ethernet": "¾░êÇ",
    "format-disconnected": "¾░û¬",
    "interval": 5,
    "tooltip": true,
    "tooltip-format": "Conectado a {essid} ({signalStrength}%)",
    "on-click": "nm-connection-editor"
  },

  "group/power": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/power",
      "custom/quit",
      "custom/reboot"
    ]
  },

  "custom/power": {
    "format": "¾▒Éï",
    "tooltip": false,
    "on-click": "shutdown now"
  },

  "custom/reboot": {
    "format": "¯½Æ",
    "tooltip": false,
    "on-click": "reboot"
  },

  "custom/quit": {
    "format": "´Çæ",
    "tooltip": false,
    "on-click": "hyprctl dispatch exit"
  },
}
